  "selectionModel": {
    "primaryApproach": "slot_based_weighted_random",
    "description": "Each recommendation mode defines a structured lineup with slots. Each slot builds an eligible candidate pool, scores candidates using mode-specific weights, then randomly selects from the high-scoring candidates while enforcing global constraints.",
    "defaultRandomization": "rotating_recommendations",
    "sameInputSameOutput": false,
    "candidateSelection": {
      "scoreCandidates": true,
      "eligiblePoolFirst": true,
      "randomizeAmongHighScorers": true,
      "highScoreBand": "top_30_percent_or_within_15_points_of_best_candidate",
      "avoidRecentlyUsedWithinSameLineup": true
    },
    "regenerateBehavior": {
      "enabled": true,
      "scope": "single_slot",
      "replacementRule": "preserve_broad_slot_role",
      "respectGlobalConstraints": true,
      "examples": {
        "longFormSlot": "replace with another eligible long-form",
        "guessingGameSlot": "replace with another guessing game",
        "showFinalSlot": "replace only with Oh Waiter or Conducted Song",
        "beginnerCircleGameSlot": "replace with another beginner-eligible circle game or low-risk exercise of comparable difficulty",
        "beginnerCapstoneSlot": "replace only with 3-Line Scenes or I Am a Tree",
        "beginnerCloserSlot": "replace only with Five Things or Name Game",
        "advancedCloserSlot": "replace only with Five Things",
        "advancedShortFormSlot": "replace with another advanced-eligible short-form game or technical rep"
      }
    },
    "transparency": {
      "showReasonTags": true,
      "reasonTagStyle": "brief_inline_tags_under_activity",
      "examples": [
        "beginner-eligible",
        "circle game",
        "listening",
        "no props",
        "show-suitable",
        "guessing game",
        "long-form slot",
        "closer"
